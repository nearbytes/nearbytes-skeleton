{
  "name": "nearbytes-skeleton",
  "version": "0.1.0",
  "description": "Nearbytes protocol foundation — crypto + log wiring, reactive store, config, filesystem watcher",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "prepack": "tsc",
    "refresh": "node scripts/refresh.mjs",
    "update": "node scripts/update.mjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nearbytes-crypto": "github:nearbytes/nearbytes-crypto",
    "nearbytes-log": "https://github.com/nearbytes/nearbytes-log.git#commit=0a1bef159ead34b542d20af74b8473e2232a90e2",
    "nearbytes-sync": "https://github.com/nearbytes/nearbytes-sync.git#commit=16f3a2c64741f9844c27dc616727fc555d7af9dd"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "yarn@4.15.0"
}
