{
  "name": "nearbytes-skeleton",
  "version": "0.1.0",
  "description": "Nearbytes application skeleton \u2014 reactive volume state, config, file watching, CLI + REPL",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nbf": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "prepare": "tsc"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "nearbytes-crypto": "nearbytes/nearbytes-crypto#main",
    "nearbytes-files": "nearbytes/nearbytes-files#main",
    "nearbytes-log": "nearbytes/nearbytes-log#main",
    "nearbytes-storage": "nearbytes/nearbytes-storage#main"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  }
}
