{
  "name": "nearbytes-skeleton",
  "version": "0.1.0",
  "description": "Nearbytes protocol foundation — crypto + log wiring, reactive store, config, filesystem watcher",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "prepack": "tsc",
    "update": "node scripts/update.mjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nearbytes-crypto": "github:nearbytes/nearbytes-crypto#6859719510764702844882b8488b35ab31f20145",
    "nearbytes-log": "github:nearbytes/nearbytes-log#a9ec85c732ede46026fa6acb08cd7a9ea366180e",
    "nearbytes-sync": "github:nearbytes/nearbytes-sync#c23283870c24cb9b6f439298dc28908672ccecf8"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "packageManager": "yarn@4.15.0"
}
