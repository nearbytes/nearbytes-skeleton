{
  "name": "nearbytes-files",
  "version": "0.1.0",
  "description": "Nearbytes file protocol — encrypted file storage on top of the event log",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "nearbytes-crypto": "nearbytes/nearbytes-crypto#main",
    "nearbytes-log": "nearbytes/nearbytes-log#main",
    "nearbytes-storage": "nearbytes/nearbytes-storage#main"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  }
}